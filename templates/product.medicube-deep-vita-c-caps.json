ky-delivery-badge {\n    position: absolute;\n    top: -10px;\n    right: -5px;\n    background: #d4af37; /* Premium Gold badge */\n    color: #fff;\n    font-size: 8px;\n    font-weight: 800;\n    padding: 3px 8px;\n    border-radius: 50px; /* Pill shape */\n    letter-spacing: 0.5px;\n    box-shadow: 0 2px 5px rgba(0,0,0,0.2);\n    z-index: 10000;\n    white-space: nowrap;\n  }\n\n  .sticky-buy-button {\n    background: #3e2723; /* Deep chocolate/brown matching the jar */\n    color: #ffffff;\n    border: none;\n    padding: 10px 22px;\n    border-radius: 12px;\n    cursor: pointer;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    line-height: 1.2;\n    font-family: 'Poppins', sans-serif;\n    transition: all 0.3s ease;\n    box-shadow: 0 4px 10px rgba(62, 39, 35, 0.3);\n  }\n  \n  .sticky-buy-button:active {\n    transform: scale(0.96);\n  }\n\n  .old-price {\n    text-decoration: line-through;\n    font-size: 10px;\n    color: #bcaaa4;\n    font-weight: 400;\n  }\n\n  .new-price {\n    font-size: 13px;\n    font-weight: 700;\n    letter-spacing: 0.2px;\n  }\n\n  @media screen and (max-width: 768px) {\n    .sticky-bar-content { gap: 8px; }\n    #sticky-timer-vita { font-size: 18px; }\n    .sticky-buy-button { padding: 10px 15px; }\n    .new-price { font-size: 12px; }\n  }\n</style>\n\n<script>\n  (function() {\n    function updateTimer() {\n      const now = new Date();\n      const targetDate = new Date();\n      // Sets countdown to the end of the current day\n      targetDate.setHours(23, 59, 59, 999);\n      \n      const diff = targetDate.getTime() - now.getTime();\n      const h = Math.floor((diff / (1000 * 60 * 60)) % 24);\n      const m = Math.floor((diff / (1000 * 60)) % 60);\n      const s = Math.floor((diff / 1000) % 60);\n      \n      const displayH = h < 10 ? \"0\" + h : h;\n      const displayM = m < 10 ? \"0\" + m : m;\n      const displayS = s < 10 ? \"0\" + s : s;\n      \n      const timerEl = document.getElementById(\"sticky-timer-vita\");\n      if(timerEl) { timerEl.innerHTML = displayH + \":\" + displayM + \":\" + displayS; }\n    }\n    \n    updateTimer();\n    setInterval(updateTimer, 1000);\n\n    window.addEventListener('scroll', function() {\n      const bar = document.getElementById('sticky-conversion-bar-vita');\n      const mainAddToCart = document.querySelector('form[action*=\"/cart/add\"] [type=\"submit\"]');\n      \n      if (mainAddToCart) {\n        const buttonRect = mainAddToCart.getBoundingClientRect();\n        // Show bar only when the main \"Add to Cart\" button leaves the viewport\n        if (buttonRect.bottom < 0) {\n          bar.style.display = 'block';\n        } else {\n          bar.style.display = 'none';\n        }\n      } else if (window.scrollY > 800) {\n        bar.style.display = 'block';\n      } else {\n        bar.style.display = 'none';\n      }\n    });\n  })();\n</script>\n{% endif %}"
